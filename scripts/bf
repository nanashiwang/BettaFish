#!/usr/bin/env bash
set -euo pipefail

APP_NAME="BettaFish"
CONFIG_FILE="${BF_CONFIG_FILE:-/etc/bettafish/bf.env}"
USE_SYSTEMD=1

log() { printf '\033[1;34m[%s]\033[0m %s\n' "$APP_NAME" "$*"; }
warn() { printf '\033[1;33m[%s]\033[0m %s\n' "$APP_NAME" "$*" >&2; }
fail() { printf '\033[1;31m[%s]\033[0m %s\n' "$APP_NAME" "$*" >&2; exit 1; }

usage() {
  cat <<USAGE
Usage: bf <command> [options]

Commands:
  update              Pull latest code and redeploy with dependency checks.
  start               Start the BettaFish compose stack.
  restart             Restart the BettaFish compose stack.
  stop                Stop the BettaFish compose stack.
  status              Show compose status and container memory usage.
  logs [service]      Follow logs. Default service: bettafish.
  heal                Health check and recover crashed/unhealthy containers.
  install-systemd     Install systemd boot/health/autoupdate units.
  enable-auto-update  Enable the systemd daily update timer.
  disable-auto-update Disable the systemd daily update timer.
  uninstall           Remove systemd units and the global bf command.
  help                Show this help.

Options:
  --no-systemd        Run compose directly instead of calling systemd.

Examples:
  bf update
  bf restart
  bf stop
  bf logs
USAGE
}

sudo_run() {
  if [[ "${EUID}" -eq 0 ]]; then
    "$@"
  else
    command -v sudo >/dev/null 2>&1 || fail "sudo is required."
    sudo "$@"
  fi
}

load_config() {
  if [[ -r "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
  APP_DIR="${BETTAFISH_HOME:-${APP_DIR:-}}"
  if [[ -z "${APP_DIR}" && -f "docker-compose.yml" && -f "Dockerfile" ]]; then
    APP_DIR="$(pwd)"
  fi
}

require_app_dir() {
  load_config
  [[ -n "${APP_DIR:-}" ]] || fail "APP_DIR is not configured. Run from the project root or run: bash scripts/deploy.sh"
  [[ -d "$APP_DIR" ]] || fail "APP_DIR does not exist: $APP_DIR"
  cd "$APP_DIR"
  [[ -f "docker-compose.yml" ]] || fail "docker-compose.yml not found in $APP_DIR"
}

compose_run() {
  if docker info >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    docker compose "$@"
  elif [[ "${EUID}" -ne 0 ]] && command -v sudo >/dev/null 2>&1 && sudo docker compose version >/dev/null 2>&1; then
    sudo docker compose "$@"
  elif command -v docker-compose >/dev/null 2>&1; then
    docker-compose "$@"
  elif [[ "${EUID}" -ne 0 ]] && command -v sudo >/dev/null 2>&1 && sudo docker-compose version >/dev/null 2>&1; then
    sudo docker-compose "$@"
  else
    fail "Docker Compose is not available."
  fi
}

docker_run() {
  if docker info >/dev/null 2>&1; then
    docker "$@"
  elif [[ "${EUID}" -ne 0 ]] && command -v sudo >/dev/null 2>&1; then
    sudo docker "$@"
  else
    fail "Docker is not available."
  fi
}

systemd_unit_exists() {
  command -v systemctl >/dev/null 2>&1 && \
    systemctl list-unit-files --type=service --no-legend bettafish.service 2>/dev/null | grep -q '^bettafish.service'
}

systemctl_or_compose() {
  local action="$1"
  shift || true
  if [[ "$USE_SYSTEMD" == "1" && "$action" != "logs" ]] && systemd_unit_exists; then
    sudo_run systemctl "$action" bettafish.service
  else
    case "$action" in
      start) compose_run up -d "$@" ;;
      stop) compose_run stop "$@" ;;
      restart) compose_run restart "$@" ;;
      *) fail "Unsupported action: $action" ;;
    esac
  fi
}

get_env_value() {
  local key="$1"
  [[ -f ".env" ]] || return 0
  awk -v key="$key" '
    index($0, key "=") == 1 { value = substr($0, length(key) + 2) }
    END { gsub(/^"/, "", value); gsub(/"$/, "", value); print value }
  ' .env
}

cmd_update() {
  require_app_dir
  command -v git >/dev/null 2>&1 || fail "git is required."

  local dirty
  dirty="$(git status --porcelain --untracked-files=no)"
  if [[ -n "$dirty" ]]; then
    fail "Tracked files are modified. Commit/stash them before bf update."
  fi

  log "Fetching latest code."
  git fetch --all --prune
  log "Fast-forwarding current branch."
  git pull --ff-only

  [[ -x "scripts/deploy.sh" ]] || chmod +x scripts/deploy.sh
  log "Redeploying with dependency checks."
  bash scripts/deploy.sh
}

cmd_start() {
  require_app_dir
  systemctl_or_compose start
}

cmd_stop() {
  require_app_dir
  systemctl_or_compose stop
}

cmd_restart() {
  require_app_dir
  systemctl_or_compose restart
}

cmd_status() {
  require_app_dir
  compose_run ps
  docker_run stats --no-stream --format 'table {{.Name}}\t{{.MemUsage}}\t{{.CPUPerc}}' bettafish bettafish-db 2>/dev/null || true
}

cmd_logs() {
  require_app_dir
  local service="${1:-bettafish}"
  compose_run logs -f --tail=200 "$service"
}

cmd_heal() {
  require_app_dir
  local port status health
  port="$(get_env_value APP_PORT)"
  [[ -n "$port" ]] || port="5050"

  status="$(docker_run inspect -f '{{.State.Status}}' bettafish 2>/dev/null || true)"
  health="$(docker_run inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{end}}' bettafish 2>/dev/null || true)"

  if [[ "$status" != "running" ]]; then
    warn "bettafish is not running; starting stack."
    compose_run up -d
    return 0
  fi

  if [[ "$health" == "unhealthy" ]]; then
    warn "bettafish is unhealthy; restarting app container."
    compose_run restart bettafish
    return 0
  fi

  if ! curl -fsSI "http://127.0.0.1:${port}/radar/" >/dev/null 2>&1; then
    warn "HTTP health check failed; restarting app container."
    compose_run restart bettafish
    return 0
  fi

  log "Health check passed."
}

write_unit() {
  local path="$1"
  local content="$2"
  local tmp
  tmp="$(mktemp)"
  printf '%s\n' "$content" > "$tmp"
  sudo_run install -m 0644 "$tmp" "$path"
  rm -f "$tmp"
}

cmd_install_systemd() {
  require_app_dir
  command -v systemctl >/dev/null 2>&1 || fail "systemd is not available on this host."

  sudo_run install -d -m 0755 /etc/bettafish
  sudo_run install -m 0755 scripts/bf /usr/local/bin/bf
  printf 'APP_DIR=%q\n' "$APP_DIR" | sudo_run tee "$CONFIG_FILE" >/dev/null

  write_unit /etc/systemd/system/bettafish.service "[Unit]
Description=BettaFish Docker Compose stack
Wants=network-online.target docker.service
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=$APP_DIR
ExecStart=/usr/local/bin/bf start --no-systemd
ExecStop=/usr/local/bin/bf stop --no-systemd
TimeoutStartSec=0
TimeoutStopSec=120
OOMPolicy=continue

[Install]
WantedBy=multi-user.target"

  write_unit /etc/systemd/system/bettafish-health.service "[Unit]
Description=BettaFish health recovery
After=bettafish.service docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/bf heal --no-systemd
OOMPolicy=continue"

  write_unit /etc/systemd/system/bettafish-health.timer "[Unit]
Description=Run BettaFish health recovery every minute

[Timer]
OnBootSec=2min
OnUnitActiveSec=1min
AccuracySec=15s
Persistent=true

[Install]
WantedBy=timers.target"

  write_unit /etc/systemd/system/bettafish-update.service "[Unit]
Description=BettaFish automatic update
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/bf update --no-systemd
OOMPolicy=continue"

  write_unit /etc/systemd/system/bettafish-update.timer "[Unit]
Description=Daily BettaFish automatic update

[Timer]
OnCalendar=*-*-* 04:30:00
RandomizedDelaySec=20min
Persistent=true

[Install]
WantedBy=timers.target"

  sudo_run systemctl daemon-reload
  sudo_run systemctl enable --now bettafish.service bettafish-health.timer
  sudo_run systemctl restart bettafish-health.timer
  log "Installed /usr/local/bin/bf and enabled bettafish.service + health timer."
  log "Auto-update timer is installed but disabled. Enable with: bf enable-auto-update"
}

cmd_enable_auto_update() {
  command -v systemctl >/dev/null 2>&1 || fail "systemd is not available on this host."
  sudo_run systemctl enable --now bettafish-update.timer
  log "Enabled bettafish-update.timer."
}

cmd_disable_auto_update() {
  command -v systemctl >/dev/null 2>&1 || fail "systemd is not available on this host."
  sudo_run systemctl disable --now bettafish-update.timer || true
  log "Disabled bettafish-update.timer."
}

cmd_uninstall() {
  if command -v systemctl >/dev/null 2>&1; then
    sudo_run systemctl disable --now bettafish-update.timer bettafish-health.timer bettafish.service 2>/dev/null || true
    sudo_run rm -f /etc/systemd/system/bettafish.service /etc/systemd/system/bettafish-health.service /etc/systemd/system/bettafish-health.timer /etc/systemd/system/bettafish-update.service /etc/systemd/system/bettafish-update.timer
    sudo_run systemctl daemon-reload
  fi
  sudo_run rm -f /usr/local/bin/bf
  sudo_run rm -rf /etc/bettafish
  log "Removed bf command and systemd units. App data and project files were not deleted."
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

COMMAND="$1"
shift

POSITIONAL=()
for arg in "$@"; do
  case "$arg" in
    --no-systemd) USE_SYSTEMD=0 ;;
    *) POSITIONAL+=("$arg") ;;
  esac
done
if [[ "${#POSITIONAL[@]}" -gt 0 ]]; then
  set -- "${POSITIONAL[@]}"
else
  set --
fi

case "$COMMAND" in
  update) cmd_update ;;
  start) cmd_start ;;
  stop) cmd_stop ;;
  restart) cmd_restart ;;
  status) cmd_status ;;
  logs) cmd_logs "${1:-bettafish}" ;;
  heal) cmd_heal ;;
  install|install-systemd) cmd_install_systemd ;;
  enable-auto-update) cmd_enable_auto_update ;;
  disable-auto-update) cmd_disable_auto_update ;;
  uninstall|remove) cmd_uninstall ;;
  help|-h|--help) usage ;;
  *) fail "Unknown command: $COMMAND" ;;
esac
